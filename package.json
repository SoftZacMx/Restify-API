{
  "name": "restify-api",
  "version": "1.0.0",
  "description": "Restify - API Serverless con AWS Lambda, Prisma y Stripe",
  "main": "dist/index.js",
  "author": "SOFTZAC",
  "license": "ISC",
  "scripts": {
    "dev": "nodemon --watch src --exec \"ts-node src/server/server.ts\"",
    "dev:lambda": "nodemon --watch src --exec \"ts-node src/index.ts\"",
    "build": "tsc",
    "start": "node dist/server/server.js",
    "start:lambda": "node dist/index.js",
    "clean": "rimraf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "prisma:generate": "prisma generate --schema=./src/core/infrastructure/database/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=./src/core/infrastructure/database/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=./src/core/infrastructure/database/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=./src/core/infrastructure/database/prisma/schema.prisma",
    "prisma:seed": "ts-node scripts/seed-db.ts",
    "seed:menu": "ts-node scripts/seed-menu-data.ts",
    "seed:general": "ts-node scripts/seed-general.ts",
    "seed:railway": "ts-node scripts/seed-railway-data.ts",
    "sync:prices:dump": "ts-node scripts/sync-menu-prices-from-dump.ts",
    "delete:orders": "ts-node scripts/delete-orders.ts",
    "release:tables": "ts-node scripts/release-tables.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "local:start": "./scripts/start-local.sh",
    "local:stop": "docker-compose down",
    "local:clean": "docker-compose down -v",
    "localstack:init": "ts-node scripts/init-localstack.ts",
    "test:dynamodb": "ts-node scripts/test-dynamodb.ts"
  },
  "prisma": {
    "schema": "./src/core/infrastructure/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.490.0",
    "@aws-sdk/client-eventbridge": "^3.490.0",
    "@aws-sdk/client-secrets-manager": "^3.490.0",
    "@aws-sdk/client-sqs": "^3.936.0",
    "@aws-sdk/lib-dynamodb": "^3.936.0",
    "@middy/core": "^6.4.5",
    "@middy/http-cors": "^6.4.5",
    "@middy/http-error-handler": "^6.4.5",
    "@middy/http-event-normalizer": "^6.4.5",
    "@middy/http-json-body-parser": "^6.4.5",
    "@middy/validator": "^6.4.5",
    "@prisma/client": "^5.7.1",
    "@types/socket.io": "^3.0.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.1.14",
    "socket.io": "^4.8.1",
    "stripe": "^14.10.0",
    "tsyringe": "^4.8.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.159",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.16",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.6",
    "@types/socket.io-client": "^1.4.36",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "prisma": "^5.7.1",
    "rimraf": "^5.0.5",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
